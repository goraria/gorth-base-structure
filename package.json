{
  "name": "gorth-base",
  "version": "1.0.1",
  "description": "",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "require": "./dist/lib/*.cjs"
    },
    "./common/*": {
      "types": "./dist/common/*.d.ts",
      "import": "./dist/common/*.js",
      "require": "./dist/common/*.cjs"
    },
    "./cores/*": {
      "types": "./dist/cores/*.d.ts",
      "import": "./dist/cores/*.js",
      "require": "./dist/cores/*.cjs"
    },
    "./cores/supabase-js": {
      "types": "./dist/cores/supabase-js.d.ts",
      "import": "./dist/cores/supabase-js.js",
      "require": "./dist/cores/supabase-js.cjs"
    },
    "./cores/supabase-pg": {
      "types": "./dist/cores/supabase-pg.d.ts",
      "import": "./dist/cores/supabase-pg.js",
      "require": "./dist/cores/supabase-pg.cjs"
    },
    "./cores/supabase-ssr": {
      "types": "./dist/cores/supabase-ssr.d.ts",
      "import": "./dist/cores/supabase-ssr.js",
      "require": "./dist/cores/supabase-ssr.cjs"
    },
    "./cores/graphql": {
      "types": "./dist/cores/graphql.d.ts",
      "import": "./dist/cores/graphql.js",
      "require": "./dist/cores/graphql.cjs"
    },
    "./cores/graphql-request": {
      "types": "./dist/cores/graphql-request.d.ts",
      "import": "./dist/cores/graphql-request.js",
      "require": "./dist/cores/graphql-request.cjs"
    },
    "./cores/graphql-tag": {
      "types": "./dist/cores/graphql-tag.d.ts",
      "import": "./dist/cores/graphql-tag.js",
      "require": "./dist/cores/graphql-tag.cjs"
    },
    "./cores/axios": {
      "types": "./dist/cores/axios.d.ts",
      "import": "./dist/cores/axios.js",
      "require": "./dist/cores/axios.cjs"
    },
    "./cores/zod": {
      "types": "./dist/cores/zod.d.ts",
      "import": "./dist/cores/zod.js",
      "require": "./dist/cores/zod.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "cores/*": [
        "dist/cores/*.d.ts"
      ],
      "common/*": [
        "dist/common/*.d.ts"
      ],
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsup --minify",
    "prepack": "pnpm build",
    "dev": "tsup src/index.ts src/common/*.ts src/cores/*.ts src/lib/*.ts --format esm,cjs --dts --out-dir dist --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "packprepare": "pnpm build",
    "update": "pnpm update",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "gorth",
    "supabase"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/postgrest-js": "^2.106.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.16.1",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "picocolors": "^1.1.1",
    "svix": "^1.95.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.4"
}
